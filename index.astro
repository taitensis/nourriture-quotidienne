---
import Layout from '../../layouts/Layout.astro';
const recipes = [{ slug: "five-spice-veggie-tofu-stir-fry", title: "Five-Spice Veggie & Tofu Stir-Fry", tags: ["vegan","asian"] }];
---
<Layout title="Recipes • My Recipes" description="All recipes in one place.">
  <h1>All Recipes</h1>
  <ul>
    {recipes.map(r => (
      <li class="card">
        <a href={`/recipes/${r.slug}/`}>{r.title}</a>
        <div style="color:var(--muted); font-size:.95rem;">
          {r.tags.join(" • ")}
        </div>
      </li>
    ))}
  </ul>
</Layout>
