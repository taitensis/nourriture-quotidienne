---
import "../styles/global.css";
import "../styles/tailwind.css";
import { Image } from "astro:assets";
import nightMode from "../assets/night-mode.png";
import languageButton from "../assets/languageButton.png";
import logoUrl from "../assets/logo.svg?url";

const { lang: propLang } = Astro.props;
const lang = propLang ?? Astro.currentLocale ?? "en";
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><slot name="title" />My Site</title>
  </head>
  <body class="bg-[var(--bg)] dark:bg-[var(--bg-dark)] text-[var(--text)] dark:text-[var(--text-dark)]">
    <header>
      <nav class="bg-[var(--bg)] dark:bg-[var(--bg-dark)] shadow-sm border-b border-[var(--border)] dark:border-[var(--border-dark)] backdrop-blur-sm">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between items-center h-16">
            
            <!-- Logo -->
            <div class="flex items-center">
              <a href={`/${lang}/`} class="flex items-center space-x-3" aria-label="Home">
                <img src={logoUrl} alt="Website Logo" class="h-8 w-auto" />
                <span class="text-xl font-semibold text-[var(--text)] dark:text-[var(--text-dark)]">
                  Nourriture Quotidienne
                </span>
              </a>
            </div>

            <!-- Desktop Navigation -->
            <div class="hidden md:flex items-center space-x-8">
              <a 
                href={`/${lang}/about`} 
                class="text-[var(--text-muted)] hover:text-[var(--text)] dark:text-[var(--text-muted-dark)] dark:hover:text-[var(--text-dark)] px-3 py-2 text-sm font-medium transition-colors duration-200"
              >
                {lang === 'fr' ? 'À propos' : 'About'}
              </a>
              <a 
                href={`/${lang}/recipes`} 
                class="text-[var(--text-muted)] hover:text-[var(--text)] dark:text-[var(--text-muted-dark)] dark:hover:text-[var(--text-dark)] px-3 py-2 text-sm font-medium transition-colors duration-200"
              >
                {lang === 'fr' ? 'Recettes' : 'Recipes'}
              </a>
            </div>

            <!-- Desktop Controls -->
            <div class="hidden md:flex items-center space-x-4">
              
              <!-- Language Dropdown -->
              <div class="relative" id="lang-dropdown">
                <button 
                  id="languageSwitcher" 
                  class="p-2 rounded-md hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] transition-colors duration-200" 
                  aria-haspopup="menu" 
                  aria-expanded="false" 
                  aria-controls="lang-menu"
                >
                  <Image src={languageButton} alt="Language" class="w-5 h-5" />
                </button>
                <ul 
                  id="lang-menu" 
                  class="absolute right-0 mt-2 w-32 bg-[var(--bg)] dark:bg-[var(--bg-dark)] rounded-md shadow-lg border border-[var(--border)] dark:border-[var(--border-dark)] py-1 z-50 hidden" 
                  role="menu"
                >
                  <li>
                    <button 
                      type="button" 
                      class="w-full text-left px-4 py-2 text-sm text-[var(--text)] dark:text-[var(--text-dark)] hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] transition-colors duration-200" 
                      data-lang="en"
                    >
                      English
                    </button>
                  </li>
                  <li>
                    <button 
                      type="button" 
                      class="w-full text-left px-4 py-2 text-sm text-[var(--text)] dark:text-[var(--text-dark)] hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] transition-colors duration-200" 
                      data-lang="fr"
                    >
                      Français
                    </button>
                  </li>
                </ul>
              </div>

              <!-- Theme Toggle -->
              <button 
                id="theme-toggle" 
                class="p-2 rounded-md hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] transition-colors duration-200 js-theme-toggle" 
                aria-label="Toggle dark mode"
              >
                <Image src={nightMode} alt="Theme" class="w-5 h-5" />
              </button>
            </div>

            <!-- Mobile Menu Button -->
            <div class="md:hidden">
              <button 
                id="menu-toggle" 
                class="p-2 rounded-md text-[var(--text)] dark:text-[var(--text-dark)] hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] transition-colors duration-200" 
                aria-label="Menu" 
                aria-controls="mobile-menu" 
                aria-expanded="false"
              >
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Mobile Menu -->
        <div 
          id="mobile-menu" 
          class="md:hidden fixed inset-0 z-50 pointer-events-none"
          role="dialog" 
          aria-modal="true"
        >
          <!-- Backdrop -->
          <div class="fixed inset-0 bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-300 ease-in-out pointer-events-none" id="mobile-backdrop"></div>
          
          <!-- Sliding Panel -->
          <div class="fixed right-0 top-0 h-full w-80 max-w-[85vw] bg-[var(--bg)]/95 dark:bg-[var(--bg-dark)]/95 backdrop-blur-xl shadow-2xl border-l border-[var(--border)] dark:border-[var(--border-dark)] transform translate-x-full transition-transform duration-300 ease-in-out" id="mobile-menu-panel">
            <!-- Header -->
            <div class="flex items-center justify-between p-6 border-b border-[var(--border)] dark:border-[var(--border-dark)]">
              <h2 class="text-lg font-semibold text-[var(--text)] dark:text-[var(--text-dark)]">Menu</h2>
              <button 
                id="close-mobile-menu"
                class="p-2 rounded-md text-[var(--text-muted)] dark:text-[var(--text-muted-dark)] hover:text-[var(--text)] dark:hover:text-[var(--text-dark)] hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] transition-colors duration-200"
                aria-label="Close menu"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>

            <!-- Content -->
            <div class="flex flex-col h-full">
              <!-- Navigation Links -->
              <div class="flex-1 p-6">
                <nav class="space-y-2">
                  <a 
                    href={`/${lang}/about`} 
                    class="group flex items-center px-4 py-3 text-base font-medium text-[var(--text)] dark:text-[var(--text-dark)] hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] rounded-lg transition-all duration-200 transform hover:translate-x-1"
                  >
                    <span class="w-2 h-2 bg-[var(--accent)] dark:bg-[var(--accent-dark)] rounded-full mr-3 opacity-0 group-hover:opacity-100 transition-opacity duration-200"></span>
                    {lang === 'fr' ? 'À propos' : 'About'}
                  </a>
                  <a 
                    href={`/${lang}/recipes`} 
                    class="group flex items-center px-4 py-3 text-base font-medium text-[var(--text)] dark:text-[var(--text-dark)] hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] rounded-lg transition-all duration-200 transform hover:translate-x-1"
                  >
                    <span class="w-2 h-2 bg-[var(--accent)] dark:bg-[var(--accent-dark)] rounded-full mr-3 opacity-0 group-hover:opacity-100 transition-opacity duration-200"></span>
                    {lang === 'fr' ? 'Recettes' : 'Recipes'}
                  </a>
                </nav>
              </div>

              <!-- Bottom Controls -->
              <div class="border-t border-[var(--border)] dark:border-[var(--border-dark)] p-6 space-y-6">
                
                <!-- Language Selection -->
                <div>
                  <h3 class="text-sm font-medium text-[var(--text-muted)] dark:text-[var(--text-muted-dark)] mb-3 uppercase tracking-wider">
                    {lang === 'fr' ? 'Langue' : 'Language'}
                  </h3>
                  <div class="flex gap-2">
                    <button 
                      class="flex-1 px-3 py-2 text-sm font-medium bg-[var(--bg-hover)] dark:bg-[var(--bg-hover-dark)] text-[var(--text)] dark:text-[var(--text-dark)] rounded-lg hover:bg-[var(--accent)]/20 dark:hover:bg-[var(--accent-dark)]/20 border border-[var(--border)] dark:border-[var(--border-dark)] transition-all duration-200" 
                      data-lang="en"
                    >
                      EN
                    </button>
                    <button 
                      class="flex-1 px-3 py-2 text-sm font-medium bg-[var(--bg-hover)] dark:bg-[var(--bg-hover-dark)] text-[var(--text)] dark:text-[var(--text-dark)] rounded-lg hover:bg-[var(--accent)]/20 dark:hover:bg-[var(--accent-dark)]/20 border border-[var(--border)] dark:border-[var(--border-dark)] transition-all duration-200" 
                      data-lang="fr"
                    >
                      FR
                    </button>
                  </div>
                </div>

                <!-- Theme Toggle -->
                <div>
                  <h3 class="text-sm font-medium text-[var(--text-muted)] dark:text-[var(--text-muted-dark)] mb-3 uppercase tracking-wider">
                    {lang === 'fr' ? 'Thème' : 'Theme'}
                  </h3>
                  <button 
                    class="w-full flex items-center justify-center px-4 py-3 text-sm font-medium bg-[var(--bg-hover)] dark:bg-[var(--bg-hover-dark)] text-[var(--text)] dark:text-[var(--text-dark)] rounded-lg hover:bg-[var(--accent)]/20 dark:hover:bg-[var(--accent-dark)]/20 border border-[var(--border)] dark:border-[var(--border-dark)] transition-all duration-200 js-theme-toggle"
                  >
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                    </svg>
                    {lang === 'fr' ? 'Basculer le thème' : 'Toggle Theme'}
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </nav>
    </header>

    <main class="prose prose-slate dark:prose-invert max-w-none">
      <div class="container mx-auto px-4 py-8">
        <slot />
      </div>
    </main>

    <footer class="bg-[var(--bg-secondary)] dark:bg-[var(--bg-secondary-dark)] border-t border-[var(--border)] dark:border-[var(--border-dark)]">
      <div class="mx-auto max-w-7xl px-4 py-8">
        <div class="text-center">
          <small class="text-[var(--text-muted)] dark:text-[var(--text-muted-dark)]">
            © 2025, Maxime Coïc · Built with ❤️
          </small>
        </div>
      </div>
    </footer>

    <script>
      // Theme toggle functionality
      function applyTheme(isDark) {
        document.documentElement.classList.toggle('dark', isDark);
      }
      
      function toggleTheme() {
        const isDark = !document.documentElement.classList.contains('dark');
        applyTheme(isDark);
        try {
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        } catch {}
      }
      
      // Initialize theme from localStorage
      try {
        const savedTheme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        applyTheme(savedTheme === 'dark' || (savedTheme === null && prefersDark));
      } catch {}
      
      // Add theme toggle listeners
      document.querySelectorAll('.js-theme-toggle').forEach(btn => {
        btn.addEventListener('click', toggleTheme);
      });

      // Language switcher functionality
      const SUPPORTED = ['en', 'fr'];
      const langDropdown = document.getElementById('lang-dropdown');
      const langSwitcher = document.getElementById('languageSwitcher');
      const langMenu = document.getElementById('lang-menu');

      function replaceLangInPath(pathname, newLang) {
        const parts = pathname.split('/');
        const first = parts[1];
        const tail = SUPPORTED.includes(first) ? parts.slice(2).join('/') : pathname.replace(/^\//, '');
        return `/${newLang}/${tail}`.replace(/\/+/g, '/');
      }

      // Desktop language dropdown
      langSwitcher?.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !langMenu.classList.contains('hidden');
        langMenu.classList.toggle('hidden');
        langSwitcher.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      });

      // Close dropdown when clicking outside
      document.addEventListener('click', (e) => {
        if (!langDropdown?.contains(e.target)) {
          langMenu?.classList.add('hidden');
          langSwitcher?.setAttribute('aria-expanded', 'false');
        }
      });

      // Language selection (desktop + mobile)
      document.querySelectorAll('[data-lang]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          const newLang = e.currentTarget.getAttribute('data-lang');
          if (!newLang || !SUPPORTED.includes(newLang)) return;
          
          const { pathname, search, hash } = window.location;
          const nextPath = replaceLangInPath(pathname, newLang);
          
          try { 
            localStorage.setItem('lang', newLang); 
          } catch {}
          
          window.location.assign(nextPath + search + hash);
        });
      });

      // Mobile menu functionality
      const menuToggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const mobileMenuPanel = document.getElementById('mobile-menu-panel');
      const closeMobileMenu = document.getElementById('close-mobile-menu');
      const mobileBackdrop = document.getElementById('mobile-backdrop');

      function openMobileMenu() {
        // Show the overlay
        mobileMenu.classList.add('pointer-events-auto');
        
        // Animate backdrop
        mobileBackdrop.classList.add('pointer-events-auto', 'opacity-100');
        mobileBackdrop.classList.remove('pointer-events-none', 'opacity-0');
        
        // Animate panel
        mobileMenuPanel.classList.remove('translate-x-full');
        mobileMenuPanel.classList.add('translate-x-0');
        
        // Update button state
        menuToggle.setAttribute('aria-expanded', 'true');
        
        // Prevent body scroll
        document.body.style.overflow = 'hidden';
        
        // Focus the close button for accessibility
        setTimeout(() => closeMobileMenu?.focus(), 150);
      }

      function closeMobileMenuFunc() {
        // Animate out
        mobileBackdrop.classList.add('pointer-events-none', 'opacity-0');
        mobileBackdrop.classList.remove('pointer-events-auto', 'opacity-100');
        
        mobileMenuPanel.classList.add('translate-x-full');
        mobileMenuPanel.classList.remove('translate-x-0');
        
        // Update button state
        menuToggle.setAttribute('aria-expanded', 'false');
        
        // Restore body scroll
        document.body.style.overflow = '';
        
        // Hide overlay after animation
        setTimeout(() => {
          mobileMenu.classList.remove('pointer-events-auto');
        }, 300);
        
        // Return focus
        menuToggle?.focus();
      }

      menuToggle?.addEventListener('click', openMobileMenu);
      closeMobileMenu?.addEventListener('click', closeMobileMenuFunc);
      mobileBackdrop?.addEventListener('click', closeMobileMenuFunc);

      // Close mobile menu on escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileMenu.classList.contains('pointer-events-auto')) {
          closeMobileMenuFunc();
        }
      });

      // Close mobile menu when clicking on links
      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', closeMobileMenuFunc);
      });
    </script>
  </body>
</html>