---
// src/layouts/Layout.astro
import "../styles/global.css";
import "../styles/tailwind.css";
import { Image } from "astro:assets";
import nightMode from "../assets/night-mode.png";
import languageButton from "../assets/languageButton.png";
import logoUrl from "../assets/logo.svg?url";

const { lang: propLang, title, mainClass } = Astro.props;
const lang = propLang ?? Astro.currentLocale ?? "en";
const RAW_BASE = import.meta.env.BASE_URL;
const BASE = RAW_BASE.endsWith("/") ? RAW_BASE : RAW_BASE + "/";
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ?? "Nourriture Quotidienne"}</title>
    <meta name="color-scheme" content="light dark" />
    <!-- Prevent light->dark flash -->
    <script>
      try {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      } catch {}
    </script>
  </head>
  <body class="bg-[var(--bg)] dark:bg-[var(--bg-dark)] text-[var(--text)] dark:text-[var(--text-dark)]">
    <header>
      <nav class="bg-[var(--bg)] dark:bg-[var(--bg-dark)] shadow-sm border-b border-[var(--border)] dark:border-[var(--border-dark)] backdrop-blur-sm">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between items-center h-16">
            <!-- Logo -->
            <div class="flex items-center">
              <a href={`${BASE}${lang}/`} class="flex items-center space-x-3" aria-label="Home">
                <img src={logoUrl} alt="Website Logo" class="h-8 w-auto" />
                <span class="text-xl font-semibold text-[var(--text)] dark:text-[var(--text-dark)]">
                  Nourriture Quotidienne
                </span>
              </a>
            </div>

            <!-- Desktop Navigation -->
            <div class="hidden md:flex items-center space-x-8">
              <a 
                href={`${BASE}${lang}/about`} 
                class="text-[var(--text-muted)] hover:text-[var(--text)] dark:text-[var(--text-muted-dark)] dark:hover:text-[var(--text-dark)] px-3 py-2 text-sm font-medium transition-colors duration-200"
              >
                {lang === 'fr' ? 'À propos' : 'About'}
              </a>
              <a 
                href={`${BASE}${lang}/recipes`} 
                class="text-[var(--text-muted)] hover:text-[var(--text)] dark:text-[var(--text-muted-dark)] dark:hover:text-[var(--text-dark)] px-3 py-2 text-sm font-medium transition-colors duration-200"
              >
                {lang === 'fr' ? 'Recettes' : 'Recipes'}
              </a>
            </div>

            <!-- Desktop Controls -->
            <div class="hidden md:flex items-center space-x-4">
              <!-- Language Dropdown -->
              <div class="relative" id="lang-dropdown">
                <button 
                  id="languageSwitcher" 
                  class="p-2 rounded-md hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] transition-colors duration-200" 
                  aria-haspopup="menu" 
                  aria-expanded="false" 
                  aria-controls="lang-menu"
                >
                  <Image src={languageButton} alt="Language" class="w-5 h-5" />
                </button>
                <ul 
                  id="lang-menu" 
                  class="absolute right-0 mt-2 w-32 bg-[var(--bg)] dark:bg-[var(--bg-dark)] rounded-md shadow-lg border border-[var(--border)] dark:border-[var(--border-dark)] py-1 z-50 hidden" 
                  role="menu"
                >
                  <li>
                    <button type="button" class="w-full text-left px-4 py-2 text-sm text-[var(--text)] dark:text-[var(--text-dark)] hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] transition-colors duration-200" data-lang="en">English</button>
                  </li>
                  <li>
                    <button type="button" class="w-full text-left px-4 py-2 text-sm text-[var(--text)] dark:text-[var(--text-dark)] hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] transition-colors duration-200" data-lang="fr">Français</button>
                  </li>
                </ul>
              </div>

              <!-- Theme Toggle (desktop) -->
              <button 
                id="theme-toggle" 
                class="p-2 rounded-md hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] transition-colors duration-200 js-theme-toggle" 
                aria-label="Toggle dark mode"
              >
                <Image src={nightMode} alt="Theme" class="w-5 h-5" />
              </button>
            </div>

            <!-- Mobile Controls -->
            <div class="md:hidden flex items-center gap-2">
              <!-- Theme Toggle (mobile) -->
              <button
                id="theme-toggle-mobile"
                class="p-2 rounded-md hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] transition-colors duration-200 js-theme-toggle"
                aria-label="Toggle dark mode"
              >
                <Image src={nightMode} alt="Theme" class="w-5 h-5" />
              </button>

              <!-- Mobile Menu Button -->
              <button 
                id="menu-toggle" 
                class="p-2 rounded-md text-[var(--text)] dark:text-[var(--text-dark)] hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] transition-colors duration-200" 
                aria-label="Menu" 
                aria-controls="mobile-menu" 
                aria-expanded="false"
              >
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
              </button>
            </div>
          </div>
        </div>
      </nav>
    </header>

    <main class={`bg-[var(--bg)] dark:bg-[var(--bg-dark)] text-[var(--text)] dark:text-[var(--text-dark)] prose prose-slate dark:prose-invert max-w-none ${mainClass ?? ""}`}>
      <div class="container mx-auto px-4 py-8">
        <slot />
      </div>
    </main>

    <footer class="bg-[var(--bg-secondary)] dark:bg-[var(--bg-secondary-dark)] border-t border-[var(--border)] dark:border-[var(--border-dark)]">
      <div class="mx-auto max-w-7xl px-4 py-8">
        <div class="text-center">
          <small class="text-[var(--text-muted)] dark:text-[var(--text-muted-dark)]">
            © 2025, Maxime Coïc · Built with ❤️
          </small>
        </div>
      </div>
    </footer>

    <!-- Mobile menu overlay (outside <nav>) -->
    <div id="mobile-menu" class="md:hidden fixed inset-0 z-[9999] pointer-events-none" role="dialog" aria-modal="true">
      <!-- Backdrop -->
      <div id="mobile-backdrop" class="fixed inset-0 bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-300 ease-in-out pointer-events-none"></div>

      <!-- Sliding Panel -->
      <div id="mobile-menu-panel" class="absolute right-0 top-0 h-full w-80 max-w-[85vw] bg-[var(--bg)]/95 dark:bg-[var(--bg-dark)]/95 backdrop-blur-xl shadow-2xl border-l border-[var(--border)] dark:border-[var(--border-dark)] translate-x-full transition-transform duration-300 ease-in-out will-change-transform">
        <!-- Header -->
        <div class="flex items-center justify-between p-6 border-b border-[var(--border)] dark:border-[var(--border-dark)]">
          <h2 class="text-lg font-semibold text-[var(--text)] dark:text-[var(--text-dark)]">Menu</h2>
          <button id="close-mobile-menu" class="p-2 rounded-md text-[var(--text-muted)] dark:text-[var(--text-muted-dark)] hover:text-[var(--text)] dark:hover:text-[var(--text-dark)] hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] transition-colors duration-200" aria-label="Close menu">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Content -->
        <div class="flex flex-col h-full">
          <div class="flex-1 p-6">
            <nav class="space-y-2">
              <a href={`${BASE}${lang}/about`} class="group flex items-center px-4 py-3 text-base font-medium text-[var(--text)] dark:text-[var(--text-dark)] hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] rounded-lg transition-all duration-200 transform hover:translate-x-1">
                <span class="w-2 h-2 bg-[var(--accent)] dark:bg-[var(--accent-dark)] rounded-full mr-3 opacity-0 group-hover:opacity-100 transition-opacity duration-200"></span>
                {lang === 'fr' ? 'À propos' : 'About'}
              </a>
              <a href={`${BASE}${lang}/recipes`} class="group flex items-center px-4 py-3 text-base font-medium text-[var(--text)] dark:text-[var(--text-dark)] hover:bg-[var(--bg-hover)] dark:hover:bg-[var(--bg-hover-dark)] rounded-lg transition-all duration-200 transform hover:translate-x-1">
                <span class="w-2 h-2 bg-[var(--accent)] dark:bg-[var(--accent-dark)] rounded-full mr-3 opacity-0 group-hover:opacity-100 transition-opacity duration-200"></span>
                {lang === 'fr' ? 'Recettes' : 'Recipes'}
              </a>
            </nav>
          </div>

          <!-- Bottom Controls -->
          <div class="border-t border-[var(--border)] dark:border-[var(--border-dark)] p-6 space-y-6">
            <div>
              <h3 class="text-sm font-medium text-[var(--text-muted)] dark:text-[var(--text-muted-dark)] mb-3 uppercase tracking-wider">
                {lang === 'fr' ? 'Langue' : 'Language'}
              </h3>
              <div class="flex gap-2">
                <button class="flex-1 px-3 py-2 text-sm font-medium bg-[var(--bg-hover)] dark:bg-[var(--bg-hover-dark)] text-[var(--text)] dark:text-[var(--text-dark)] rounded-lg hover:bg-[var(--accent)]/20 dark:hover:bg-[var(--accent-dark)]/20 border border-[var(--border)] dark:border-[var(--border-dark)] transition-all duration-200" data-lang="en">EN</button>
                <button class="flex-1 px-3 py-2 text-sm font-medium bg-[var(--bg-hover)] dark:bg-[var(--bg-hover-dark)] text-[var(--text)] dark:text-[var(--text-dark)] rounded-lg hover:bg-[var(--accent)]/20 dark:hover:bg-[var(--accent-dark)]/20 border border-[var(--border)] dark:border-[var(--border-dark)] transition-all duration-200" data-lang="fr">FR</button>
              </div>
            </div>

            <div>
              <h3 class="text-sm font-medium text-[var(--text-muted)] dark:text-[var(--text-muted-dark)] mb-3 uppercase tracking-wider">
                {lang === 'fr' ? 'Thème' : 'Theme'}
              </h3>
              <button class="w-full flex items-center justify-center px-4 py-3 text-sm font-medium bg-[var(--bg-hover)] dark:bg-[var(--bg-hover-dark)] text-[var(--text)] dark:text-[var(--text-dark)] rounded-lg hover:bg-[var(--accent)]/20 dark:hover:bg-[var(--accent-dark)]/20 border border-[var(--border)] dark:border-[var(--border-dark)] transition-all duration-200 js-theme-toggle">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                </svg>
                {lang === 'fr' ? 'Basculer le thème' : 'Toggle Theme'}
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script define:vars={{ base: BASE }}>
      // --- Theme: fully inline (no .ts import) ---
      (function(){
        var KEY='theme';
        function apply(t){ document.documentElement.classList.toggle('dark', t==='dark'); try{localStorage.setItem(KEY,t);}catch{} }
        function compute(){
          try{ var s=localStorage.getItem(KEY); if(s==='light'||s==='dark') return s; }catch{}
          return matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        // init (in case head script didn't run)
        apply(compute());
        function toggle(){ apply(document.documentElement.classList.contains('dark')?'light':'dark'); }
        function ready(fn){ if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',fn,{once:true});} else fn(); }
        ready(function(){
          document.querySelectorAll('.js-theme-toggle, #theme-toggle').forEach(function(btn){
            btn.addEventListener('click', function(e){ e.preventDefault(); toggle(); });
          });
        });
      })();

      // --- Language switcher (robust + base-aware) ---
      try {
        const SUPPORTED = ['en', 'fr'];
        const langDropdown = document.getElementById('lang-dropdown');
        const langSwitcher = document.getElementById('languageSwitcher');
        const langMenu = document.getElementById('lang-menu');

        // Build new URL under repo base
        function buildLangURL(newLang) {
          const url = new URL(window.location.href);
          let base = `${baseVar}`; // injected below
          if (!base.endsWith('/')) base += '/';
          let path = url.pathname;                    // e.g. /repo/en/recipes/foo
          if (base !== '/' && path.startsWith(base)) {
            path = path.slice(base.length - 1);       // -> /en/recipes/foo
          }
          path = path.replace(/^\/+/, '');            // -> en/recipes/foo
          const parts = path.split('/').filter(Boolean);
          if (SUPPORTED.includes(parts[0])) parts.shift();
          const tail = parts.join('/');
          const next = `${base}${newLang}/${tail}`.replace(/\/+/g, '/');
          return next + url.search + url.hash;
        }

        // Dropdown open/close
        langSwitcher?.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = !langMenu.classList.contains('hidden');
          langMenu.classList.toggle('hidden');
          langSwitcher.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
        });
        document.addEventListener('click', (e) => {
          if (!langDropdown?.contains(e.target)) {
            langMenu?.classList.add('hidden');
            langSwitcher?.setAttribute('aria-expanded', 'false');
          }
        });

        // Change language (desktop + mobile)
        document.querySelectorAll('[data-lang]').forEach((btn) => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            const newLang = btn.getAttribute('data-lang');
            if (!newLang || !SUPPORTED.includes(newLang)) return;
            try { localStorage.setItem('lang', newLang); } catch {}
            window.location.assign(buildLangURL(newLang));
          });
        });
      } catch (err) {
        console.warn('Lang switcher init failed:', err);
      }

      // --- Mobile menu (robust & isolated) ---
      try {
        const menuToggle = document.getElementById('menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        const panel = document.getElementById('mobile-menu-panel');
        const closeBtn = document.getElementById('close-mobile-menu');
        const backdrop = document.getElementById('mobile-backdrop');

        if (menuToggle && mobileMenu && panel && backdrop) {
          const lockScroll = () => document.documentElement.classList.add('overflow-hidden');
          const unlockScroll = () => document.documentElement.classList.remove('overflow-hidden');

          const open = () => {
            mobileMenu.classList.add('pointer-events-auto');
            backdrop.classList.remove('pointer-events-none', 'opacity-0');
            backdrop.classList.add('pointer-events-auto', 'opacity-100');
            panel.classList.remove('translate-x-full');
            panel.classList.add('translate-x-0');
            mobileMenu.setAttribute('data-open', 'true');
            menuToggle.setAttribute('aria-expanded', 'true');
            lockScroll();
            setTimeout(() => closeBtn?.focus(), 150);
          };
          const close = () => {
            backdrop.classList.add('pointer-events-none', 'opacity-0');
            backdrop.classList.remove('pointer-events-auto', 'opacity-100');
            panel.classList.add('translate-x-full');
            panel.classList.remove('translate-x-0');
            mobileMenu.setAttribute('data-open', 'false');
            menuToggle.setAttribute('aria-expanded', 'false');
            unlockScroll();
            setTimeout(() => mobileMenu.classList.remove('pointer-events-auto'), 300);
            menuToggle?.focus();
          };

          menuToggle.addEventListener('click', (e) => { e.preventDefault(); open(); });
          closeBtn?.addEventListener('click', (e) => { e.preventDefault(); close(); });
          backdrop.addEventListener('click', (e) => { e.preventDefault(); close(); });
          document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && mobileMenu.getAttribute('data-open') === 'true') close(); });
          panel.querySelectorAll('a').forEach(a => a.addEventListener('click', () => close()));
        }
      } catch (err) {
        console.warn('Mobile menu init failed:', err);
      }
    </script>

    <!-- Inject BASE for buildLangURL -->
    <script>var baseVar = {JSON.stringify(BASE)};</script>
  </body>
</html>
