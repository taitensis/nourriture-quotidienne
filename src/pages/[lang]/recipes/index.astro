---
import Layout from "../../../layouts/Layout.astro";
import { SUPPORTED_LANGS } from "../../../lib/i18n";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

const BASE = import.meta.env.BASE_URL;

/** Import build-time de toutes les images recettes dans src/assets/recipes (sous-dossiers inclus) */
const imageModules = import.meta.glob<ImageMetadata>(
  "../../../assets/recipes/**/*.{jpg,jpeg,png,webp,avif}",
  { eager: true, import: "default" }
);

/** Associe le frontmatter { src } à un asset importé par nom de fichier */
function resolveHero(img?: { src?: string } | null): ImageMetadata | null {
  if (!img?.src) return null;
  const filename = img.src.split("/").pop();
  if (!filename) return null;
  for (const [path, mod] of Object.entries(imageModules)) {
    if (path.endsWith("/" + filename)) return mod as ImageMetadata;
  }
  return null;
}

export async function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: string };

const all = await getCollection("recipes");
const recipes = all
  .filter((r) => r.slug.startsWith(`${lang}/`))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const localSlug = (full: string) => full.split("/").slice(1).join("/");
const pageTitle = lang === "fr" ? "Recettes" : "Recipes";
---

<Layout lang={lang} title={`${pageTitle} • My Recipes`} mainClass="wide">
  <h1>{pageTitle}</h1>

  {recipes.length === 0 ? (
    <p>{lang === "fr" ? "Aucune recette pour cette langue." : "No recipes for this language yet."}</p>
  ) : (
    <div class="mx-auto grid gap-6 justify-items-center grid-cols-[repeat(auto-fit,minmax(18rem,1fr))] max-w-[1400px] px-4">
      {recipes.map((r) => {
        const heroFM = r.data.images?.[0];          // { src, alt } du frontmatter
        const heroAsset = resolveHero(heroFM);       // ImageMetadata ou null

        return (
          <article class="w-full max-w-sm rounded overflow-hidden shadow-lg bg-[var(--surface)] border border-[var(--border)]">
            {heroAsset ? (
              <Image
                src={heroAsset}
                alt={heroFM?.alt || r.data.title}
                class="w-full aspect-video object-cover"
                loading="lazy"
                sizes="(min-width:1024px) 33vw, (min-width:640px) 50vw, 100vw"
              />
            ) : heroFM ? (
              /* Fallback si le src pointe vers /public */
              <img
                class="w-full aspect-video object-cover"
                src={heroFM.src}
                alt={heroFM.alt || r.data.title}
                loading="lazy"
                decoding="async"
              />
            ) : (
              /* Placeholder si aucune image */
              <div class="w-full aspect-video bg-gray-100 dark:bg-gray-800" aria-hidden="true" />
            )}

            <div class="px-6 py-4">
              <h3 class="font-bold text-xl mb-2">
                <a href={`${BASE}${lang}/recipes/${localSlug(r.slug)}`}>{r.data.title}</a>
              </h3>
              {r.data.description && (
                <p class="text-gray-700 dark:text-gray-300 text-base line-clamp-3">
                  {r.data.description}
                </p>
              )}
            </div>
          </article>
        );
      })}
    </div>
  )}
</Layout>
