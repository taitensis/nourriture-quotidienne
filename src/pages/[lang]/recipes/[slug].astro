---
import Layout from "../../../layouts/Layout.astro";
import { getEntryBySlug, getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import scaleUrl from "../../../scripts/scale-ingredients.ts?url";
import ArrowUp from "../../../assets/up.svg?raw";
import ArrowDown from "../../../assets/down.svg?raw";

/* Resolve images referenced by filename in frontmatter */
const imageModules = import.meta.glob<ImageMetadata>(
  "../../../assets/recipes/*.{jpg,jpeg,png,webp,avif}",
  { eager: true, import: "default" }
);
function findImageFromFrontmatter(srcStr?: string): ImageMetadata | null {
  if (!srcStr) return null;
  const filename = srcStr.split("/").pop();
  if (!filename) return null;
  for (const [path, mod] of Object.entries(imageModules)) {
    if (path.endsWith("/" + filename)) return mod as ImageMetadata;
  }
  return null;
}

/* Dynamic routes: /[lang]/recipes/[slug] from collection slugs like "en/my-slug" */
export async function getStaticPaths() {
  const all = await getCollection("recipes");
  return all.map((entry) => {
    const [lang, ...rest] = entry.slug.split("/");
    return { params: { lang, slug: rest.join("/") } };
  });
}

const { lang, slug } = Astro.params;
const entry = await getEntryBySlug("recipes", `${lang}/${slug}`);
if (!entry) throw new Error(`Recipe not found: ${lang}/${slug}`);

const { Content } = await entry.render();
const data = entry.data;

/* Support grouped or flat ingredients */
const groups =
  data.ingredient_groups?.length ? data.ingredient_groups :
  data.ingredients?.length ? [{ ingredients: data.ingredients }] :
  [];

/* For scaling "yield" text */
// derive a number from "4 servings" / "4 portions"
const yieldParsed = (() => {
  const m = String(data.yield ?? '').match(/(\d+([.,]\d+)?)/);
  return m ? Number(m[1].replace(',', '.')) : 1;
})();

// base == the number the author wrote the ingredients for
const yieldBase = Number(data.yield_base ?? yieldParsed);
// default UI value (what you show on first render)
const yieldDefault = Number(data.yield_default ?? yieldParsed);

const initialScale = yieldDefault / yieldBase;

/* For JSON-LD time helpers */
const toISO = (s: string) => {
  if (!s) return "PT0M";
  const m = /(?:(\d+)\s*h)?\s*(?:(\d+)\s*min)?/i.exec(s) || [];
  const H = m[1] ? `${m[1]}H` : "";
  const M = m[2] ? `${m[2]}M` : (!H ? "0M" : "");
  return `PT${H}${M}`;
};

/* Hero */
const heroFM = data.images?.[0];
const heroAsset = findImageFromFrontmatter(heroFM?.src);

/* fraction display for initial server render */
const toFrac = (n: number) => {
  const whole = Math.floor(n);
  const frac = n - whole;
  const denoms = [8, 6, 5, 4, 3, 2];
  let best = { d: 1, num: Math.round(frac), err: Math.abs(frac - Math.round(frac)) };
  for (const d of denoms) {
    const num = Math.round(frac * d);
    const err = Math.abs(frac - num / d);
    if (err < best.err) best = { d, num, err };
  }
  if (best.num === 0) return String(whole || 0);
  if (best.num === best.d) return String(whole + 1);
  return whole ? `${whole} ${best.num}/${best.d}` : `${best.num}/${best.d}`;
};
---
<Layout
  lang={lang}
  title={`${data.title} • Nourriture Quotidienne`}
  description={`${yieldDefault} ${lang === "fr" ? "portions" : "servings"}${data.time?.total ? " • " + data.time.total : ""}`}
  mainClass="prose-dense wide"
>
  <!-- JSON-LD -->
  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Recipe",
      name: data.title,
      image: (data.images || []).map((i: any) => i.src),
      recipeYield: `${yieldDefault} ${lang === "fr" ? "portions" : "servings"}`,
      prepTime: toISO(data.time?.prep),
      cookTime: toISO(data.time?.cook),
      totalTime: toISO(data.time?.total),
      recipeIngredient: (groups.flatMap((g:any)=>g.ingredients)).map((ing:any) => {
        if (ing && typeof ing === "object" && "qty" in ing) {
          const unit = ing.unit ? ` ${ing.unit}` : "";
          return `${toFrac(ing.qty * initialScale)}${unit} ${ing.item}`;
        }
        return String(ing);
      }),
      recipeInstructions: (data.steps || []).map((s: string) => ({ "@type": "HowToStep", text: s }))
    })}
  </script>

  <article class="recipe grid grid-cols-1">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="crumb text-[var(--text-muted)]">
      <a href={`${import.meta.env.BASE_URL}${lang}/recipes`} class="crumb-link">← {lang === "fr" ? "Toutes les recettes" : "All recipes"}</a>
    </nav>

    <!-- Hero -->
    <header class="recipe-header grid grid-cols-2">
      <div class="recipe-header-left grid grid-rows-2">
      <h1 id="recipe-title" class="content-center">
        {data.title}
      </h1>

      <div class="grid grid-cols-2 gap-4 text-[var(--text)] dark:text-[var(--text-dark)]">
          <!-- Servings with stepper -->
          <div class="p-4 flex items-center gap-2 border border-4 rounded-4xl border-(border-d) dark:border-(border-d-dark) bg-[var(--bg)] dark:bg-[var(--bg-dark)]">
            <strong class="font-medium">{lang === "fr" ? "Portions :" : "Servings:"}</strong>
            <span data-yield data-yield-base={yieldBase} class="tabular-nums">{yieldDefault}</span>

            <button class="h-8 w-8 rounded-full bg-[var(--bg)] dark:bg-[var(--bg-dark)] text-[var(--text-muted)] hover:text-[var(--text)] grid place-items-center" data-scale="-" aria-label={lang === "fr" ? "Diminuer les portions" : "Decrease servings"} >
              <span class="h-4 w-4 [&>svg]:h-full [&>svg]:w-full [&>svg]:block [&>svg_*]:fill-current" set:html={ArrowDown} /> </button>
            <button class="h-8 w-8 rounded-full bg-[var(--bg)] dark:bg-[var(--bg-dark)] text-[var(--text-muted)] hover:text-[var(--text)] grid place-items-center" data-scale="+" aria-label={lang === "fr" ? "Augmenter les portions" : "Increase servings"} >
              <span class="h-4 w-4 [&>svg]:h-full [&>svg]:w-full [&>svg]:block [&>svg_*]:fill-current" set:html={ArrowUp} /> </button>
          </div>

          <!-- Difficulty (optional) -->
          <div class="p-4 border border-4 rounded-4xl border-(border-d) dark:border-(border-d-dark) bg-(--bg) dark:bg-[var(--bg-dark)]">
            <span class="inline-flex items-center gap-1">
              <strong class="font-medium">{lang === "fr" ? "Difficulté :" : "Difficulty:"}</strong>
              <span class="font-medium">{data.difficulty ?? "—"}</span>
            </span>
          </div>

          <!-- Prep -->
          <div class="p-4 border border-4 rounded-4xl border-(border-d) dark:border-(border-d-dark) bg-[var(--bg)] dark:bg-[var(--bg-dark)]">
            <span class="inline-flex items-center gap-1">
              <strong class="font-medium">{lang === "fr" ? "Préparation :" : "Prep:"}</strong>
              <span class="font-medium">{data.time?.prep ?? "—"}</span>
            </span>
          </div>

          <!-- Cook -->
          <div class="p-4 border border-4 rounded-4xl border-(border-d) dark:border-(border-d-dark) bg-[var(--bg)] dark:bg-[var(--bg-dark)]">
            <span class="inline-flex items-center gap-1">
              <strong class="font-medium">{lang === "fr" ? "Cuisson :" : "Cook:"}</strong>
              <span class="font-medium">{data.time?.cook ?? "—"}</span>
            </span>
          </div>
        </div>
      </div>

      <div class="recipe-header-right">
        {heroFM ? (
        <figure class="m-0">
          {heroAsset ? (
            <Image
              src={heroAsset}
              alt={heroFM.alt || data.title}
              class="hero-img"
              loading="eager"
              fetchpriority="high"
            />
          ) : (
            <img
              src={heroFM.src}
              alt={heroFM.alt || data.title}
              class="hero-img"
              loading="eager"
              fetchpriority="high"
            />
          )}
        </figure>
      ) : null}
      </div>
    </header>

    <!-- Intro/body from Markdown -->
    <section class="my-4">
      <Content />
    </section>

    <!-- Ingredients -->
    <section id="ingredients" class="ingredients">
      <h2 id="h2ingredients">{lang === "fr" ? "Ingrédients" : "Ingredients"}</h2>

      <aside class="not-prose mb-3 flex flex-wrap items-center gap-3 text-sm text-[var(--text-muted)]" aria-label="Recipe meta">



        <div class="flex items-center gap-2">
  <strong class="font-medium">{lang === "fr" ? "Portions:" : "Servings:"}</strong>
  <!-- This is what your JS already reads for the servings number -->
  <span data-yield data-yield-base={yieldBase} class="tabular-nums">{data.yield}</span>

  <!-- Reuse your data-scale hooks; just swap the visuals -->
  <button
  class="h-8 w-8 rounded-full border border-[var(--border)] 
         bg-[var(--bg)] dark:bg-[var(--bg-dark)] 
         text-[var(--text-muted)] hover:text-[var(--text)] 
         grid place-items-center"
  data-scale="-"
  aria-label={lang === "fr" ? "Diminuer les portions" : "Decrease servings"}
>
  <span class="h-4 w-4 [&>svg]:h-full [&>svg]:w-full [&>svg]:block [&>svg_*]:fill-current" set:html={ArrowDown} />
</button>

<button
  class="h-8 w-8 rounded-full border border-[var(--border)] 
         bg-[var(--bg)] dark:bg-[var(--bg-dark)] 
         text-[var(--text-muted)] hover:text-[var(--text)] 
         grid place-items-center"
  data-scale="+"
  aria-label={lang === "fr" ? "Augmenter les portions" : "Increase servings"}
>
  <span class="h-4 w-4 [&>svg]:h-full [&>svg]:w-full [&>svg]:block [&>svg_*]:fill-current" set:html={ArrowUp} />
</button>


  <!-- Keep your scale readout so your JS can still target/update it.
       You can visually downplay it; or hide it with sr-only if you’re sure your JS doesn’t need it visible. -->
  <!-- <span id="scale" class="tabular-nums text-[var(--text-muted)]">1×</span> -->

  <!-- <button class="px-2 py-0.5 border border-[var(--border)] rounded" data-scale="reset">
    {lang === "fr" ? "Réinit." : "Reset"}
  </button> -->
</div>
      </aside>

      {groups.map((group) => (
        <section class="mb-3">
          {group.title && <h3 class="mt-2 mb-1">{group.title}</h3>}
          <ul class="ingredient-list">
            {group.ingredients.map((item, index) => (
              <li class="ingredient-item">
                <label class="ingredient-label">
                  <input 
                    type="checkbox" 
                    class="ingredient-checkbox"
                    id={`ingredient-${group.title || 'main'}-${index}`}
                  />
                  <span class="ingredient-text">{item}</span>
                </label>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </section>

    <!-- Directions -->
    <section id="directions" class="directions">
      <h2 id="h2directions">{lang === "fr" ? "Préparation" : "Directions"}</h2>
      <ol class="list-decimal pl-6 space-y-1">
        {data.steps.map((step) => <li>{step}</li>)}
      </ol>
    </section>

    <!-- Notes -->
    {data.notes?.length > 0 && (
      <section class="notes">
        <h2 id="h2notes">{lang === "fr" ? "Notes" : "Notes"}</h2>
        <div class="pl-6 space-y-1">
          {data.notes.map((n) => <div>{n}</div>)}
        </div>
      </section>
    )}
  </article>

  <!-- External, bundled scripts -->
  <script type="module" src={scaleUrl}></script>
  
  <!-- Recipe-specific script -->
  <script define:vars={{ lang }}>
    // Sticky recipe title for this recipe page
    const recipeTitle = document.getElementById('recipe-title');
    if (recipeTitle) {
      // Create sticky title element
      const stickyTitle = document.createElement('div');
      stickyTitle.className = 'recipe-title-sticky';
      stickyTitle.innerHTML = `
        <div class="container">
          <h4>${recipeTitle.textContent}</h4>
          </nav>
        </div>
      `;
      document.body.appendChild(stickyTitle);

      // Show/hide sticky title based on scroll
      let heroHeight = recipeTitle.offsetTop + recipeTitle.offsetHeight;
      
      window.addEventListener('scroll', () => {
        if (window.scrollY > heroHeight) {
          stickyTitle.classList.add('show');
        } else {
          stickyTitle.classList.remove('show');
        }
      });

      // Smooth scroll to sections
      stickyTitle.querySelectorAll('a[href^="#"]').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const target = document.querySelector(link.getAttribute('href'));
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    }
  </script>
</Layout>